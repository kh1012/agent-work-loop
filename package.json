{
  "name": "agent-work-loop",
  "version": "0.6.34",
  "description": "같은 실패를 두 번 하지 않는 도구. AI 에이전트가 한 일과 확인한 내용을 파일로 남깁니다.",
  "type": "module",
  "bin": {
    "awl": "dist/cli.js"
  },
  "files": ["dist", "engine"],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": ["agent", "llm", "claude-code", "codex", "workflow"],
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "prepublishOnly": "node ./engine/templates/block-publish.mjs && pnpm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

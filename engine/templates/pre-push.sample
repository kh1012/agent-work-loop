#!/bin/sh
# awl safety hook: a human at an interactive terminal can push directly.
# This hook has no way to tell a human's `git push` apart from one an agent
# ran programmatically, so it checks for a controlling terminal instead
# (agents/CI invocations don't have one; opening /dev/tty fails for them).
if [ "${AWL_ALLOW_PUSH:-}" = "1" ]; then
  exit 0
fi
if ( exec 3<>/dev/tty ) 2>/dev/null; then
  exit 0
fi
echo "❌ awl: git push is blocked (no interactive terminal detected). A human at a terminal can push directly; otherwise use AWL_ALLOW_PUSH=1 git push." >&2
exit 1
